{
  "name": "pointing-sound-board",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "vercel-build": "npm run build && npm run build:sw",
    "build:sw": "rimraf dist/sw.js && workbox generateSW config/workbox-config.cjs",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{vue,js,json}\"",
    "clean": "rimraf dist coverage",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "postcss": "^8.5.15",
    "tough-cookie": "^6.0.1",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.11",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.6",
    "workbox-cli": "^7.4.1"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true
  },
  "staticPath": "static",
  "lint-staged": {
    "*.{vue,js,json}": "prettier --write"
  }
}
